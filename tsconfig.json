{
  "compilerOptions": {
    "target": "ES6",                          /* Versão do JS que o Mac vai gerar */
    "module": "ESNext",                      /* Necessário para o type="module" no HTML */
    "lib": ["DOM", "ESNext"],                /* Permite usar document, window, etc. */
    "outDir": "./dist",                      /* Pasta onde o app.js será criado */
    "rootDir": "./src",                      /* Onde o TypeScript vai procurar seu código */
    "strict": true,                          /* Ativa o modo rigoroso (melhor para QA) */
    "esModuleInterop": true,                 /* Compatibilidade com módulos */
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*"]                    /* Compila tudo dentro de src */
}